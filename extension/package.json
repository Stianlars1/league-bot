{
  "name": "peeked-companion-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Peeked Companion browser extension — polls Riot's Live Client Data and forwards frames to the Peeked relay.",
  "type": "module",
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "watch": "tsx esbuild.config.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
