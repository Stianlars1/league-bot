{
  "manifest_version": 3,
  "name": "Peeked Companion",
  "version": "0.1.0",
  "description": "Realtime League of Legends data for Peeked — reads your local Live Client API and streams it to your Peeked view.",
  "permissions": ["storage", "offscreen", "alarms"],
  "host_permissions": [
    "https://127.0.0.1:2999/*",
    "https://peeked.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background-sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
