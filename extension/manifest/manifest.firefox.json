{
  "manifest_version": 3,
  "name": "Counter Companion",
  "version": "0.1.0",
  "description": "Realtime League of Legends data for Counter — reads your local Live Client API and streams it to your Counter view.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://127.0.0.1:2999/*",
    "https://counter.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "scripts": ["background-event.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "counter-companion@counter.app",
      "strict_min_version": "115.0"
    }
  }
}
